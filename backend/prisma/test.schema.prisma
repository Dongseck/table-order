// Test-only mirror of schema.prisma using SQLite for fast, dependency-free tests.
// Keep model fields in sync with schema.prisma.
// Run: prisma generate --schema=./prisma/test.schema.prisma

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/test-client"
}

datasource db {
  provider = "sqlite"
  url      = "file:./test.db"
}

model Store {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adminUsers AdminUser[]
  tables     Table[]
  categories Category[]
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  storeId      Int
  username     String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id])

  @@unique([storeId, username])
}

model Table {
  id               Int      @id @default(autoincrement())
  storeId          Int
  tableNumber      Int
  passwordHash     String
  currentSessionId Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  store    Store          @relation(fields: [storeId], references: [id])
  sessions TableSession[]

  @@unique([storeId, tableNumber])
}

model TableSession {
  id        Int       @id @default(autoincrement())
  tableId   Int
  startedAt DateTime  @default(now())
  endedAt   DateTime?

  table  Table   @relation(fields: [tableId], references: [id])
  orders Order[]
}

model Category {
  id        Int      @id @default(autoincrement())
  storeId   Int
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store      @relation(fields: [storeId], references: [id])
  items MenuItem[]
}

model MenuItem {
  id          Int      @id @default(autoincrement())
  categoryId  Int
  name        String
  price       Int
  description String?
  imageUrl    String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id])
}

model Order {
  id          Int      @id @default(autoincrement())
  sessionId   Int
  tableId     Int
  orderNumber Int
  status      String   @default("PENDING")
  totalAmount Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  session TableSession @relation(fields: [sessionId], references: [id])
  items   OrderItem[]

  @@unique([sessionId, orderNumber])
}

model OrderItem {
  id           Int    @id @default(autoincrement())
  orderId      Int
  menuItemName String
  unitPrice    Int
  quantity     Int

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderHistory {
  id               Int      @id @default(autoincrement())
  tableId          Int
  tableNumber      Int
  sessionId        Int
  sessionStartedAt DateTime
  sessionEndedAt   DateTime
  orderNumber      Int
  status           String
  totalAmount      Int
  orderedAt        DateTime
  archivedAt       DateTime @default(now())

  items OrderHistoryItem[]
}

model OrderHistoryItem {
  id              Int    @id @default(autoincrement())
  orderHistoryId  Int
  menuItemName    String
  unitPrice       Int
  quantity        Int

  orderHistory OrderHistory @relation(fields: [orderHistoryId], references: [id], onDelete: Cascade)
}
